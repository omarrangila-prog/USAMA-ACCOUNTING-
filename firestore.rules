rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Login has been removed — the app runs as a single shared workspace under
    // users/bond-workspace/…  Since there is no authentication, this path is
    // open. This is intended for a single-tenant, in-house deployment only.
    //
    // ⚠️  Anyone with the project's web config can read/write this workspace.
    //     If you later need multi-user access control, re-introduce Firebase
    //     Auth and scope by request.auth.uid instead.
    match /users/bond-workspace/{collection}/{docId} {
      allow read, write: if true;
    }
  }
}
