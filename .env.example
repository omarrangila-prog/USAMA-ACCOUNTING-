# ---------------------------------------------------------------------------
# Firebase configuration — copy this file to ".env" and fill in your values.
#   cp .env.example .env
#
# Where to find these: Firebase Console -> Project Settings -> General ->
#   Your apps -> Web app -> "SDK setup and configuration" -> Config.
#
# NOTE: These are Firebase *web* config values. They are NOT secret — they ship
# in the browser bundle by design. Your data is protected by Firestore Security
# Rules (firestore.rules), not by hiding these keys. We keep them in .env only
# so the repo stays clean and each environment can point at its own project.
#
# .env is gitignored and must NOT be committed.
# ---------------------------------------------------------------------------

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Set to "true" to run fully offline against local mock data (no Firebase needed).
# Great for demos. When false/unset (and Firebase keys are present), real
# Firebase Auth + Firestore are used.
VITE_USE_MOCK=false
