# Copy this file to .env and fill with your Firebase project credentials.
# Firebase Console -> Project Settings -> General -> Your apps -> Web app -> Config

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Set to "true" to run fully offline against local mock data (no Firebase needed).
# Great for demos. When false/unset, real Firebase Auth + Firestore are used.
VITE_USE_MOCK=false
